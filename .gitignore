# Godot-specific ignores
.import/
export.cfg
export_presets.cfg
.mono/
data_*/

games/
logs/
tests/
scores/

# Build artifacts
builds/
*.x86_64
*.pck
*.AppImage

# Godot auto-generated files
.godot/
*.translation

# OS-specific
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# Runtime data created next to the launcher (CWD-relative in dev runs).
# The directories themselves are tracked via .gitkeep; contents are ignored.
/games/*
!/games/.gitkeep
/logs/*
!/logs/.gitkeep
/scores/*
!/scores/.gitkeep
/launcher_state.json

# Temporary files
*.tmp
*.bak
*.old
